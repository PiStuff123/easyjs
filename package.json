  "main": "src/index.js",
  "module": "src/index.mjs",
  "types": "index.d.ts",
  "files": [
    "src",
    "index.d.ts"
  ],
  "exports": {
    ".": {
      "require": "./src/index.js",
      "import": "./src/index.mjs"
    },
    "./*": {
      "require": "./src/*.js",
      "import": "./src/*.mjs"
    },
    "./array/*": {
      "require": "./src/array/*.js",
      "import": "./src/array/*.mjs"
    },
    "./string/*": {
      "require": "./src/string/*.js",
      "import": "./src/string/*.mjs"
    },
    "./math/*": {
      "require": "./src/math/*.js",
      "import": "./src/math/*.mjs"
    },
    "./object/*": {
      "require": "./src/object/*.js",
      "import": "./src/object/*.mjs"
    },
    "./util/*": {
      "require": "./src/util/*.js",
      "import": "./src/util/*.mjs"
    }
  },
